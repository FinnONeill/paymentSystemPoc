#############################################
# Sample environment configuration for app  #
#############################################

# Web server
# Optional; defaults to 3000 if not set
PORT=3000

# Kafka configuration
# Unique identifier for the Kafka client
KAFKA_CLIENT_ID=nacha-layer-kafka-client

# Comma-separated list of Kafka brokers, e.g. "broker-1:9092,broker-2:9092"
KAFKA_BROKERS=broker-1:9092,broker-2:9092

# Enable SSL for Kafka connection ("true" or "false")
KAFKA_SSL=false

# Topic used for test messages
KAFKA_TEST_TOPIC=nacha-layer-test-topic

# AWS Glue Schema Registry configuration
GLUE_REGION=eu-west-1
GLUE_REGISTRY_NAME=nacha-layer-registry
GLUE_SCHEMA_NAME=nacha-layer-test-schema

